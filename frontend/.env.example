# Copy to .env.local (gitignored by Vite) or set in your CI / host build settings.
# Vite only exposes variables prefixed with VITE_.

# Backend REST API (include /api/bugtracker/v1 suffix)
VITE_API_BASE_URL=http://localhost:8080/api/bugtracker/v1

# Optional: WebSocket URL for live notifications. If omitted, derived from VITE_API_BASE_URL
# (same host, wss:// when the API URL is https://).
# VITE_WS_URL=ws://localhost:8080/ws-notifications-native
